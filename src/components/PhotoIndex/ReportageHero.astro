---
import CFImage from '@/components/CFImage/CFImage.astro';
import css from '@/styles/Photo.module.scss';
import { useTranslations, getLocalizedPath } from '@/i18n/utils';
import type { ui } from '@/i18n/ui';
import type { Reportage } from '@/data/reportages';

interface Props {
  reportage: Reportage;
  lang: keyof typeof ui;
}

const { reportage, lang } = Astro.props;
const t = useTranslations(lang);
---

<a
  class={css.hero}
  href={getLocalizedPath(reportage.href, lang)}
  data-aos
>
  <CFImage
    src={reportage.cover}
    alt={reportage.coverAlt}
    widths={[800, 1200, 1600]}
    sizes='100vw'
  />
  <div class={css.heroOverlay}>
    <span class={css.kicker}>{t('photo.featured')}</span>
    <h2 class={css.heroTitle}>{reportage.title[lang]}</h2>
    <p class={css.heroSubtitle}>{reportage.subtitle[lang]}</p>
    <div class={css.entryMeta}>
      <div class={css.metaItem}>
        <span class={css.metaLabel}>{t('photo.metaLocation')}</span>
        <span class={css.metaValue}>{reportage.location}</span>
      </div>
      <div class={css.metaItem}>
        <span class={css.metaLabel}>{t('photo.metaYear')}</span>
        <span class={css.metaValue}>{reportage.year}</span>
      </div>
    </div>
  </div>
  <span class={css.entryArrow}>↗</span>
</a>
