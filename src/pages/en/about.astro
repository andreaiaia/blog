---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import CFImage from '@/components/CFImage/CFImage.astro';
import css from '@/styles/About.module.scss';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<script
  src='https://cdnjs.cloudflare.com/polyfill/v3/polyfill.min.js?version=4.8.0&features=IntersectionObserver'
  integrity='sha384-ac2tY+FDuY06qMD2drYkVmGsfdnlZ+PYRyrM1HEheFY7T+o8lxfTJ7NnRuyX0l7H'
  crossorigin='anonymous'
></script>

<BaseLayout
  title={t('site.title')}
  descrition={t('site.description')}
  headerMode='solid'
  lang={lang}
>
  <main class={css.page}>
    <div class={css.header} data-aos>
      <p class={css.sectionTag}>About me</p>
      <h1 class={css.headline}>
        Andrea Bianchi —<br /><em>documentary photographer</em>
      </h1>
      <p class={css.headerSubtitle}>
        Out with a camera since 2012.
      </p>
    </div>

    <section class={css.bioSection}>
      <div class={css.bioGrid}>
        <div data-aos>
          <div class={css.bioText}>
            <p>
              I got into photography in 2012, after reading a blog post about
              long exposures — how keeping the shutter open could capture the
              light trails of passing cars.
            </p>
            <p>
              I grabbed my father's Nikon D50, propped it on a wall, set it to
              30 seconds, and took my first shot. The excitement I felt then is
              the same I feel every time I press the shutter now.
            </p>
            <p>
              Since then I've photographed in Italy, Japan, Iceland, and
              Turkey. I'm drawn to photography as an act of witnessing —
              reportage isn't about chasing the extraordinary, it's about
              having the patience to let the ordinary reveal itself.
            </p>
          </div>
          <div class={css.originPhotoWrap}>
            <CFImage
              className={css.originPhoto}
              src='misc/la-mia-prima-foto.jpg'
              alt='The first photo, a long exposure of moving cars in Matera.'
              widths={[480, 800]}
              sizes='(max-width: 850px) 100vw, 55vw'
            />
            <p class={css.originCaption}>The photo that started it all, 2012.</p>
          </div>
        </div>
        <div class={css.bioPhotoWrap} data-aos>
          <CFImage
            className={css.bioPhoto}
            src='me/profile-pic.jpg'
            alt='A photograph of me, Andrea.'
            widths={[480, 800]}
            sizes='(max-width: 850px) 100vw, 45vw'
          />
        </div>
      </div>
    </section>

    <section class={css.socialSection} data-aos>
      <p class={css.socialLabel}>Find me on</p>
      <div class={css.socialLinks}>
        <a
          class={css.socialLink}
          href='TODO_INSTAGRAM'
          target='_blank'
          rel='noopener noreferrer'
        >Instagram</a>
        <a
          class={css.socialLink}
          href='TODO_YOUTUBE'
          target='_blank'
          rel='noopener noreferrer'
        >YouTube</a>
        <a
          class={css.socialLink}
          href='TODO_GITHUB'
          target='_blank'
          rel='noopener noreferrer'
        >GitHub</a>
      </div>
    </section>
  </main>

  <script is:inline>
    (function () {
      function setup() {
        var elements = document.querySelectorAll('[data-aos]');
        var observer = new IntersectionObserver(
          function (entries, obs) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.07 }
        );
        elements.forEach(function (el) {
          observer.observe(el);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setup);
      } else {
        setup();
      }
    })();
  </script>
</BaseLayout>
