---
import Header from '@/components/Header/Header.astro';
import Footer from '@/components/Footer/Footer.svelte';
import { getAlternateLangUrl } from '@/i18n/utils';

import '@/styles/normalize.css';
import '@/styles/global.css';
import '@/styles/_globals.module.scss';

const {
  title,
  description,
  headerMode,
  lang = 'it',
  image = 'https://andreabianchi.me/cdn-cgi/image/format=jpeg,quality=80,width=1200/https://images.andreabianchi.me/matera/sassi-laputa.jpg',
} = Astro.props;

const alternateLangUrl = getAlternateLangUrl(Astro.url.pathname, lang);
const alternateLang = lang === 'it' ? 'en' : 'it';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <link rel='canonical' href={Astro.url} />
    <link rel='alternate' hreflang={lang} href={Astro.url} />
    <link
      rel='alternate'
      hreflang={alternateLang}
      href={new URL(alternateLangUrl, Astro.site)}
    />
    <!-- Open Graph / Facebook -->
    <meta property='og:type' content='website' />
    <meta property='og:url' content={Astro.url} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:image' content={new URL(image, Astro.url)} />
    <meta property='og:locale' content={lang === 'it' ? 'it_IT' : 'en_US'} />
    <!-- Twitter -->
    <meta property='twitter:card' content='summary_large_image' />
    <meta property='twitter:url' content={Astro.url} />
    <meta property='twitter:title' content={title} />
    <meta property='twitter:description' content={description} />
    <meta property='twitter:image' content={new URL(image, Astro.url)} />
    <!-- Analytics -->
    <script
      is:inline
      defer
      src='https://cloud.umami.is/script.js'
      data-website-id='a9430e6c-d81c-496b-a486-a073439d114c'></script>
  </head>

  <body>
    <Header headerMode={headerMode} />
    <slot />
    <Footer lang={lang} alternateLangUrl={alternateLangUrl} />
  </body>
</html>
