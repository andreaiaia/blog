---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import CFImage from '@/components/CFImage/CFImage.astro';
import css from '@/styles/Home.module.scss';
import PostThumbnail from '@/components/PostThumbnail/PostThumbnail.svelte';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allAlbums = await getCollection('albums');
const albums = allAlbums
  .filter((a) => a.data.published)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const allPosts = await getCollection('blog-en');
const posts = allPosts
  .filter((p) => p.data.published)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<script
  src='https://cdnjs.cloudflare.com/polyfill/v3/polyfill.min.js?version=4.8.0&features=IntersectionObserver'
></script>

<BaseLayout
  title={t('site.title')}
  descrition={t('site.description')}
  headerMode='transparent'
  lang={lang}
>
  <main>
    <!-- ─── Hero ──────────────────────────────────────────────────────────── -->
    <section class={css.section} id='welcome'>
      <CFImage
        className={css.photoBackground}
        src='matera/sassi-laputa.jpg'
        alt='The famous Sassi of Matera.'
        widths={[480, 800, 1200, 2400]}
        sizes='100vw'
      />
      <div class={css.heroGradient}></div>
      <div class={css.heroContainer}>
        <div class={css.heroBottomContent} data-aos>
          <div class={css.heroLeft}>
            <p class={css.heroLabel}>{t('home.identity')}</p>
            <h1 class={css.heroTitle}>
              The world speaks <br />
              <em>I listen</em>
            </h1>
          </div>
          <div class={css.heroCaption}>
            <strong>{t('home.heroCaptionLocation')}</strong>
            {t('home.heroCaption')}
          </div>
        </div>
        <a class={css.scrollLineWrap} href='#intro'>
          <div class={css.scrollLine}></div>
        </a>
      </div>
    </section>

    <!-- ─── Intro ─────────────────────────────────────────────────────────── -->
    <section class={css.introSection} id='intro'>
      <div class={css.introInner}>
        <div data-aos>
          <p class={css.sectionTag} data-num='01'>{t('home.introLabel')}</p>
          <h2 class={css.introHeadline}>
            I photograph what <em>moves me</em>
          </h2>
          <div class={css.introBio}>
            <p>
              <em>
                I photograph what reaches me — a face, a light, a moment that
                won't come again.
              </em>
            </p>
            <p>
              <em>
                I don't look for the story: the story finds me, and I try to
                hold it still.
              </em>
            </p>
            <p>
              Since 2012 I've been walking around with a camera. I've learned by
              looking, reading, and getting things wrong. This blog is the
              notebook of what I've seen.
            </p>
          </div>
        </div>
        <div class={css.introRight} data-aos>
          <div class={css.profileImgWrap}>
            <CFImage
              className={css.profileImg}
              src='me/profile-pic.jpg'
              alt='A picture of me, Andrea.'
              widths={[480, 800]}
              sizes='(max-width: 850px) 100vw, 45vw'
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Reportage strip ───────────────────────────────────────────────── -->
    <section class={css.reportageStrip} id='reportage'>
      <div class={css.reportageInner}>
        <div data-aos>
          <p class={css.reportageQuote}>
            &quot;Beautiful things don&apos;t ask for attention.&quot;
          </p>
          <p class={css.reportageQuoteAttribution}>
            — The Secret Life of Walter Mitty (2013)
          </p>
        </div>
        <div data-aos>
          <p class={css.reportageStatement}>
            I'm interested in photography as an act of witness. Reportage isn't
            chasing the extraordinary — it's having the patience to wait for the
            ordinary to reveal itself.
          </p>
          <div class={css.tagsList}>
            <span class={css.tag}>Documentary</span>
            <span class={css.tag}>Reportage</span>
            <span class={css.tag}>Southern Italy</span>
            <span class={css.tag}>Human landscape</span>
            <span class={css.tag}>Street</span>
            <span class={css.tag}>Nature</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Photography ───────────────────────────────────────────────────── -->
    <section class={css.photoSection} id='photography'>
      <div class={css.sectionHeader} data-aos>
        <h2 class={css.sectionTitle}>Portfolios</h2>
        <a href='/en/photo' class={css.viewAllLink}>{t('home.viewAll')}</a>
      </div>
      <div class={css.photoGridNew} data-aos>
        {
          albums[0] && (
            <a
              href={`/en/photo/${albums[0].id}`}
              class={`${css.photoCardNew} ${css.photoCardTall}`}
            >
              <CFImage
                className={css.photoCardNewImg}
                src={albums[0].data.cover}
                alt={albums[0].data.coverAlt}
                widths={[480, 800, 1200]}
                sizes='(max-width: 768px) 100vw, 50vw'
              />
              <div class={css.photoCardNewOverlay}>
                <span class={css.photoCardLabel}>{albums[0].data.title}</span>
              </div>
            </a>
          )
        }
        {
          albums[1] && (
            <a href={`/en/photo/${albums[1].id}`} class={css.photoCardNew}>
              <CFImage
                className={css.photoCardNewImg}
                src={albums[1].data.cover}
                alt={albums[1].data.coverAlt}
                widths={[480, 800]}
                sizes='(max-width: 768px) 50vw, 25vw'
              />
              <div class={css.photoCardNewOverlay}>
                <span class={css.photoCardLabel}>{albums[1].data.title}</span>
              </div>
            </a>
          )
        }
        {
          albums[2] && (
            <a href={`/en/photo/${albums[2].id}`} class={css.photoCardNew}>
              <CFImage
                className={css.photoCardNewImg}
                src={albums[2].data.cover}
                alt={albums[2].data.coverAlt}
                widths={[480, 800]}
                sizes='(max-width: 768px) 50vw, 25vw'
              />
              <div class={css.photoCardNewOverlay}>
                <span class={css.photoCardLabel}>{albums[2].data.title}</span>
              </div>
            </a>
          )
        }
        {
          albums[3] && (
            <a href={`/en/photo/${albums[3].id}`} class={css.photoCardNew}>
              <CFImage
                className={css.photoCardNewImg}
                src={albums[3].data.cover}
                alt={albums[3].data.coverAlt}
                widths={[480, 800]}
                sizes='(max-width: 768px) 50vw, 25vw'
              />
              <div class={css.photoCardNewOverlay}>
                <span class={css.photoCardLabel}>{albums[3].data.title}</span>
              </div>
            </a>
          )
        }
        <a href='/en/photo' class={css.photoCardCtaCell}>
          <span class={css.photoCardCtaText}>
            View<br />all<br />projects →
          </span>
        </a>
      </div>
    </section>

    <!-- ─── Blog ──────────────────────────────────────────────────────────── -->
    <section class={css.blogSection} id='blog'>
      <div class={css.blogInner}>
        <div class={css.sectionHeader} data-aos>
          <h2 class={css.sectionTitle}>From the blog</h2>
          <a href='/en/blog' class={css.viewAllLink}>{t('home.viewAllBlog')}</a>
        </div>
        <div class={css.blogGridEqual} data-aos>
          {posts.map((post) => <PostThumbnail post={post} />)}
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (function () {
      function setup() {
        var elements = document.querySelectorAll('[data-aos]');
        var observer = new IntersectionObserver(
          function (entries, obs) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.07 }
        );
        elements.forEach(function (el) {
          observer.observe(el);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setup);
      } else {
        setup();
      }
    })();
  </script>
</BaseLayout>
