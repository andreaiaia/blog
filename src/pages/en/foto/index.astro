---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import css from '@/styles/Foto.module.scss';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import CFImage from '@/components/CFImage/CFImage.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const albums = (await getCollection('albums'))
  .filter(({ data }) => data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const row1 = albums.slice(0, 2);
const row2 = albums.slice(2, 4);
const row3 = albums.slice(4);
---

<BaseLayout
  title={t('nav.photo')}
  descrition='My photography: capturing the essence of a moment'
  headerMode='solid'
  lang={lang}
>
  <script is:inline>
    (function () {
      function setup() {
        var els = document.querySelectorAll('[data-aos]');
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('animate');
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.06 }
        );
        els.forEach(function (el) {
          observer.observe(el);
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setup);
      } else {
        setup();
      }
    })();
  </script>

  <main class={css.page}>
    <div class={css.pageHeader}>
      <span class={css.pageTitle}>Photography</span>
      <span class={css.pageCount}>{albums.length} series</span>
    </div>

    <div class={css.grid}>
      {
        row1.length > 0 && (
          <div class={`${css.row} ${css.row21}`}>
            {row1.map(({ id, data }) => (
              <a class={css.card} href={`/en/photo/${id}`} data-aos>
                <div class={css.cardThumb}>
                  <CFImage
                    src={data.cover}
                    alt={data.coverAlt}
                    widths={[480, 800, 1200]}
                    sizes='(max-width: 480px) 100vw, (max-width: 720px) 50vw, 33vw'
                  />
                </div>
                <div class={css.cardBody}>
                  {data.category && (
                    <span class={css.cardTag}>{data.category}</span>
                  )}
                  <div class={css.cardMeta}>
                    <h2 class={css.cardName}>{data.title}</h2>
                    <span class={css.cardArrow}>↗</span>
                  </div>
                  {data.description && (
                    <p class={css.cardDesc}>{data.description}</p>
                  )}
                  <div class={css.cardLine} />
                </div>
              </a>
            ))}
          </div>
        )
      }

      {
        row2.length > 0 && (
          <div class={`${css.row} ${css.row12}`}>
            {row2.map(({ id, data }) => (
              <a class={css.card} href={`/en/photo/${id}`} data-aos>
                <div class={css.cardThumb}>
                  <CFImage
                    src={data.cover}
                    alt={data.coverAlt}
                    widths={[480, 800, 1200]}
                    sizes='(max-width: 480px) 100vw, (max-width: 720px) 50vw, 33vw'
                  />
                </div>
                <div class={css.cardBody}>
                  {data.category && (
                    <span class={css.cardTag}>{data.category}</span>
                  )}
                  <div class={css.cardMeta}>
                    <h2 class={css.cardName}>{data.title}</h2>
                    <span class={css.cardArrow}>↗</span>
                  </div>
                  {data.description && (
                    <p class={css.cardDesc}>{data.description}</p>
                  )}
                  <div class={css.cardLine} />
                </div>
              </a>
            ))}
          </div>
        )
      }

      {
        row3.length > 0 && (
          <div class={`${css.row} ${css.row21}`}>
            {row3.map(({ id, data }) => (
              <a class={css.card} href={`/en/photo/${id}`} data-aos>
                <div class={css.cardThumb}>
                  <CFImage
                    src={data.cover}
                    alt={data.coverAlt}
                    widths={[360, 480]}
                    sizes='(max-width: 480px) 50vw, 25vw'
                  />
                </div>
                <div class={css.cardBody}>
                  {data.category && (
                    <span class={css.cardTag}>{data.category}</span>
                  )}
                  <div class={css.cardMeta}>
                    <h2 class={css.cardName}>{data.title}</h2>
                    <span class={css.cardArrow}>↗</span>
                  </div>
                  {data.description && (
                    <p class={css.cardDesc}>{data.description}</p>
                  )}
                  <div class={css.cardLine} />
                </div>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </main>
</BaseLayout>
